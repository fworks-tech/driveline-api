# Django Settings
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-change-in-production

# Allowed hosts (comma-separated, required for production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Docker Compose / PostgreSQL development (preferred)
DATABASE_URL=postgresql://spotter:spotter@db:5432/spotter
REDIS_URL=redis://redis:6379/0

# Railway Production (PostgreSQL)
# Railway auto-provides DATABASE_URL, but you can override:
# DATABASE_URL=postgresql://postgres:PASSWORD@containers-us-west-XXX.railway.app:5432/railway

# CORS Settings (allow frontend origin)
# Development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production (Vercel frontend + Railway backend)
# CORS_ALLOWED_ORIGINS=https://spotter-eld-logging-app.vercel.app

# External APIs (usually no auth required for free tiers)
# Nominatim is part of OpenStreetMap (free, rate-limited)
# OSRM is free and open-source
# API_USER_AGENT: User-Agent string for outbound API requests (default: SpotterELD/1.0 (support@spotter-eld.app))
API_USER_AGENT=SpotterELD/1.0 (support@spotter-eld.app)

# Logging & Monitoring
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
DJANGO_ENV=development

# Production Deployment Checklist
# [ ] Set DEBUG=False in production
# [ ] Generate DJANGO_SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# [ ] Set ALLOWED_HOSTS to your domain(s)
# [ ] Set CORS_ALLOWED_ORIGINS to your frontend URL(s)
# [ ] Ensure DATABASE_URL points to production PostgreSQL
