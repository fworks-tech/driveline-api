# Django Settings
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
# Local Development (SQLite)
DATABASE_URL=sqlite:///db.sqlite3

# Staging/Production (PostgreSQL on Railway)
# DATABASE_URL=postgresql://user:password@host:5432/database_name

# CORS Settings (allow frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# For production
# CORS_ALLOWED_ORIGINS=https://spotter-eld.app,https://staging-spotter.vercel.app

# External APIs (usually no auth required for free tiers)
# Nominatim is part of OpenStreetMap (free, rate-limited)
# OSRM is free and open-source

# Logging
LOG_LEVEL=INFO
