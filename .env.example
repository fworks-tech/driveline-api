# Django Settings
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-change-in-production

# Allowed hosts (comma-separated, required for production)
ALLOWED_HOSTS=localhost,127.0.0.1
# Production: ALLOWED_HOSTS=driveline-api-production.up.railway.app

# Database Configuration
# Supabase PostgreSQL (production & development)
DATABASE_URL=postgresql://postgres.YOUR_SUPABASE_USER:YOUR_SUPABASE_PASSWORD@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# Docker Compose / PostgreSQL development (alternative)
# DATABASE_URL=postgresql://driveline:driveline@db:5432/driveline
# REDIS_URL=redis://redis:6379/0

# Railway Production (PostgreSQL - legacy, not recommended)
# DATABASE_URL=postgresql://postgres:PASSWORD@containers-us-west-XXX.railway.app:5432/railway

# CORS Settings (allow frontend origin)
# Development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production (Vercel frontend + Railway backend)
# CORS_ALLOWED_ORIGINS=https://driveline-eld-app.vercel.app

# External APIs (usually no auth required for free tiers)
# Nominatim is part of OpenStreetMap (free, rate-limited)
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_TIMEOUT=10

# OSRM is free and open-source
OSRM_URL=https://router.project-osrm.org/route/v1/driving
OSRM_TIMEOUT=30

# API_USER_AGENT: User-Agent string for outbound API requests
API_USER_AGENT=Driveline/1.0 (support@driveline.app)

# Cache timeouts (seconds)
GEOCODE_CACHE_TIMEOUT=86400
ROUTE_CACHE_TIMEOUT=172800

# Logging & Monitoring
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
DJANGO_ENV=development

# Production Deployment Checklist
# [ ] Set DEBUG=False in production
# [ ] Generate DJANGO_SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# [ ] Set ALLOWED_HOSTS to your domain(s)
# [ ] Set CORS_ALLOWED_ORIGINS to your frontend URL(s)
# [ ] Ensure DATABASE_URL points to production PostgreSQL
