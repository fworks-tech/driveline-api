    "components": {
        "schemas": {
            "LogbookDay": {
                "type": "object",
                "properties": {
                    "day": {
                        "type": "integer"
                    },
                    "events": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/LogbookEvent"
                        }
                    }
                },
                "required": [
                    "day",
                    "events"
                ]
            },
            "LogbookEvent": {
                "type": "object",
                "properties": {
                    "status": {
                        "type": "string",
                        "maxLength": 50
                    },
                    "start_minute": {
                        "type": "integer"
                    },
                    "duration_minutes": {
                        "type": "integer"
                    },
                    "label": {
                        "type": "string",
                        "maxLength": 255
                    }
                },
                "required": [
                    "duration_minutes",
                    "label",
                    "start_minute",
                    "status"
                ]
            },
            "Marker": {
                "type": "object",
                "properties": {
                    "lat": {
                        "type": "number",
                        "format": "double"
                    },
                    "lon": {
                        "type": "number",
                        "format": "double"
                    },
                    "type": {
                        "type": "string",
                        "maxLength": 50
                    },
                    "label": {
                        "type": "string",
                        "maxLength": 255
                    }
                },
                "required": [
                    "label",
                    "lat",
                    "lon",
                    "type"
                ]
            },
            "TripInput": {
                "type": "object",
                "properties": {
                    "current_location": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "pickup_location": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "dropoff_location": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "cycle_hours_used": {
                        "type": "number",
                        "format": "double",
                        "maximum": 70,
                        "minimum": 0
                    }
                },
                "required": [
                    "current_location",
                    "cycle_hours_used",
                    "dropoff_location",
                    "pickup_location"
                ]
            },
            "TripOutput": {
                "type": "object",
                "properties": {
                    "route_coordinates": {
                        "type": "array",
                        "items": {
                            "type": "array",
                            "items": {
                                "type": "number",
                                "format": "double"
                            }
                        }
                    },
                    "markers": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Marker"
                        }
                    },
                    "logbook_days": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/LogbookDay"
                        }
                    },
                    "trip_summary": {
                        "$ref": "#/components/schemas/TripSummary"
                    }
                },
                "required": [
                    "logbook_days",
                    "markers",
                    "route_coordinates",
                    "trip_summary"
                ]
            },
            "TripSummary": {
                "type": "object",
                "properties": {
                    "total_distance_miles": {
                        "type": "number",
                        "format": "double"
                    },
                    "total_trip_hours": {
                        "type": "number",
                        "format": "double"
                    },
                    "total_drive_hours": {
                        "type": "number",
                        "format": "double"
                    },
                    "legs": {
                        "type": "integer"
                    },
                    "rest_stops": {
                        "type": "integer"
                    },
                    "fuel_stops": {
                        "type": "integer"
                    }
                },
                "required": [
                    "fuel_stops",
                    "legs",
                    "rest_stops",
                    "total_distance_miles",
                    "total_drive_hours",
                    "total_trip_hours"
                ]
            }
        },
        "securitySchemes": {
            "basicAuth": {
                "type": "http",
                "scheme": "basic"
            },
            "cookieAuth": {
                "type": "apiKey",
                "in": "cookie",
                "name": "sessionid"
            }
        }
    }
}